<Application x:Class="LSPDFRManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LSPDFRManager.ViewModels"
             xmlns:views="clr-namespace:LSPDFRManager.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- MVVM navigation: map each ViewModel to its View -->
            <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
                <views:LibraryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:InstallViewModel}">
                <views:InstallView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
                <views:ConfigView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BrowseViewModel}">
                <views:BrowseView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
                <views:DiagnosticsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProfilesViewModel}">
                <views:ProfilesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BackupsViewModel}">
                <views:BackupsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                <views:HistoryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LogViewerViewModel}">
                <views:LogViewerView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
