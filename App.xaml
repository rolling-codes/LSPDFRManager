<Application x:Class="LSPDFRManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LSPDFRManager.ViewModels"
             xmlns:views="clr-namespace:LSPDFRManager.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- MVVM navigation: map each ViewModel to its View -->
            <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
                <views:LibraryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:InstallViewModel}">
                <views:InstallView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:KeysViewModel}">
                <views:KeysView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
