<Window x:Class="LSPDFRManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LSPDFR Manager"
        Height="780" Width="1180"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackground}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderSubtle}">
            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Background="{StaticResource AccentSecondary}" CornerRadius="4"
                                Padding="6,2" Margin="0,0,8,0">
                            <TextBlock Text="LSPDFR" Foreground="White"
                                       FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Manager" Foreground="{StaticResource TextStrong}"
                                   FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Grid/>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource AppBackground}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
