<Window x:Class="LSPDFRManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LSPDFRManager.ViewModels"
        Title="LSPDFR Manager"
        Height="780" Width="1180"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Sidebar ════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#080D14"
                BorderThickness="0,0,1,0"
                BorderBrush="#1A2B45">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,22,20,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <Border Background="#1D4ED8" CornerRadius="6"
                                Padding="6,3" Margin="0,0,8,0">
                            <TextBlock Text="LSPDFR" Foreground="White"
                                       FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Manager" Foreground="#F0F4FF"
                                   FontSize="17" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="v1.1.1 · GTA V Mod Manager"
                               Foreground="#3D4F6A" FontSize="10"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Library"
                            Tag="{Binding IsLibraryActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Library"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Install"
                            Tag="{Binding IsInstallActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Install"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Browse"
                            Tag="{Binding IsBrowseActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Browse"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Config"
                            Tag="{Binding IsConfigActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Configs"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            Tag="{Binding IsSettingsActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,16">
                    <Separator/>

                    <!-- LSPDFR Status card -->
                    <Border Background="#0F1828" CornerRadius="8" Padding="12,10" Margin="0,4,0,8">
                        <StackPanel>
                            <TextBlock Text="ENVIRONMENT" Foreground="#3D4F6A"
                                       FontSize="9" FontWeight="SemiBold" Margin="0,0,0,7"/>

                            <!-- GTA V row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsGtaPathValid}" Value="True">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="GTA V" Foreground="#8B9AB2" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status.GtaVersion}"
                                           Foreground="#3D4F6A" FontSize="10"
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- LSPDFR row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsLspdfrInstalled}" Value="True">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="LSPDFR" Foreground="#8B9AB2" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status.LspdfrVersion}"
                                           Foreground="#3D4F6A" FontSize="10"
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- ScriptHookV row -->
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsScriptHookVInstalled}" Value="True">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="ScriptHookV" Foreground="#8B9AB2" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status.ScriptHookVVersion}"
                                           Foreground="#3D4F6A" FontSize="10"
                                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Launch LSPDFR button -->
                    <Button Style="{StaticResource LaunchButton}"
                            Content="&#xE768;  Launch LSPDFR"
                            FontFamily="Segoe MDL2 Assets, Segoe UI"
                            Command="{Binding LaunchLspdfrCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,10"
                            Padding="12,8"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#3D4F6A" FontSize="10"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Spacer to push status to bottom -->
                <Grid/>

            </DockPanel>
        </Border>

        <!-- ══ Content area ═══════════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Background="#0F1117"/>
    </Grid>
</Window>
