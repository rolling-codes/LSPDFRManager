<Window x:Class="LSPDFRManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LSPDFR Manager"
        Icon="pack://application:,,,/Resources/app.ico"
        Height="840" Width="1240"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Sidebar ══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackground}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderSubtle}">
            <DockPanel>

                <!-- Wordmark -->
                <StackPanel DockPanel.Dock="Top" Margin="20,26,20,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <!-- Badge icon -->
                        <Border Width="30" Height="30" CornerRadius="6"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1D4ED8" Offset="0"/>
                                    <GradientStop Color="#2563EB" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="LSPDFR" Foreground="{StaticResource AccentPrimary}"
                                       FontSize="14" FontWeight="Bold" LineHeight="16"/>
                            <TextBlock Text="MANAGER" Foreground="{StaticResource AccentGold}"
                                       FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="v3.6.0 — Command Center"
                               Foreground="{StaticResource TextSubtle}" FontSize="10"
                               Margin="40,0,0,0"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Top" Height="1"
                           Fill="{StaticResource BorderSubtle}" Margin="16,0,16,12"/>

                <!-- Nav group: main -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0,8,4">

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Home">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHomeActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Home" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Library">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLibraryActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Library" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Install">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInstallActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Install" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Browse">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBrowseActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Browse" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                </StackPanel>

                <!-- Separator + Tools group label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="TOOLS" Style="{StaticResource SectionLabel}"
                           Margin="22,8,0,4"/>

                <StackPanel DockPanel.Dock="Top" Margin="8,0,8,4">

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Diagnostics">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiagnosticsActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Diagnostics" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Profiles">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProfilesActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Profiles" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Backups">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackupsActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Backups" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="History">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistoryActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="History" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Command="{Binding NavigateCommand}" CommandParameter="Logs">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLogViewerActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Logs" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                </StackPanel>

                <!-- Settings pinned at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,16">
                    <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="8,0,8,10"/>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══ Content area ═════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource AppBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Global error banner -->
            <Border Grid.Row="0"
                    Background="{StaticResource ErrorBackground}"
                    BorderBrush="{StaticResource ErrorBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="18,10"
                    Visibility="{Binding HasGlobalError, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="{StaticResource ErrorText}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding GlobalErrorMessage}"
                               Foreground="{StaticResource ErrorText}"
                               FontSize="13" VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
