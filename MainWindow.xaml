<Window x:Class="LSPDFRManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LSPDFRManager.ViewModels"
        Title="LSPDFR Manager"
        Height="780" Width="1180"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Sidebar ════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource Sidebar}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource Border}">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Background="{StaticResource AccentDark}" CornerRadius="4"
                                Padding="6,2" Margin="0,0,8,0">
                            <TextBlock Text="LSPDFR" Foreground="White"
                                       FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Manager" Foreground="{StaticResource TextPrimary}"
                                   FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="v1.5.0 · GTA V Mod Manager"
                               Foreground="{StaticResource TextFaint}" FontSize="11"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Library"
                            Tag="{Binding IsLibraryActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Library" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Install"
                            Tag="{Binding IsInstallActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Install" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Browse"
                            Tag="{Binding IsBrowseActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Browse" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Config"
                            Tag="{Binding IsConfigActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Configs" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            Tag="{Binding IsSettingsActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Settings" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,24">
                    <!-- LSPDFR Status card -->
                    <Border Background="{StaticResource Bg}" CornerRadius="12" Padding="14,12" Margin="0,0,0,16"
                            BorderThickness="1" BorderBrush="{StaticResource Border}">
                        <StackPanel>
                            <TextBlock Text="ENVIRONMENT" Foreground="{StaticResource TextFaint}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                            <!-- GTA V row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource Danger}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsGtaPathValid}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="GTA V" Foreground="{StaticResource TextMuted}" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status.GtaVersion}"
                                           Foreground="{StaticResource TextFaint}" FontSize="11"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- LSPDFR row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource Danger}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsLspdfrInstalled}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="LSPDFR" Foreground="{StaticResource TextMuted}" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status.LspdfrVersion}"
                                           Foreground="{StaticResource TextFaint}" FontSize="11"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- ScriptHookV row -->
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource Danger}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsScriptHookVInstalled}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="ScriptHookV" Foreground="{StaticResource TextMuted}" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status.ScriptHookVVersion}"
                                           Foreground="{StaticResource TextFaint}" FontSize="11"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Launch LSPDFR button -->
                    <Button Style="{StaticResource LaunchButton}"
                            Content="&#xE768;  Launch LSPDFR"
                            FontFamily="Segoe MDL2 Assets, Segoe UI"
                            Command="{Binding LaunchLspdfrCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,12"
                            Padding="12,10"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextFaint}" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <!-- Spacer to push status to bottom -->
                <Grid/>

            </DockPanel>
        </Border>

        <!-- ══ Content area ═══════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="#0F1117">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Global error banner -->
            <Border Grid.Row="0"
                    Background="#2D1B1B"
                    BorderBrush="#DC2626"
                    BorderThickness="0,0,0,1"
                    Padding="14,10"
                    Visibility="{Binding HasGlobalError, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding GlobalErrorMessage}"
                           Foreground="#FCA5A5"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- Main content -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
