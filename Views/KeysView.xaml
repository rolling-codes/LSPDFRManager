<UserControl x:Class="LSPDFRManager.Views.KeysView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <DockPanel Margin="28,24,28,16">

        <!-- ── Header ─────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Key Manager" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="Store and apply mod license key files."
                       Foreground="{StaticResource TextMuted}" FontSize="13"/>
        </StackPanel>

        <!-- ── Status bar ─────────────────────────────────── -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource TextMuted}"
                   FontSize="12"
                   Margin="0,8,0,0"/>

        <!-- ── Two‑column layout ──────────────────────────── -->
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Key list -->
            <DockPanel Grid.Column="0">
                <!-- Add buttons -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Add from file"
                            Command="{Binding AddFromFileCommand}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="Add manually"
                            Command="{Binding AddManuallyCommand}"/>
                </StackPanel>

                <!-- Keys list -->
                <ListBox ItemsSource="{Binding Keys}"
                         SelectedItem="{Binding SelectedKey}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Surface}"
                                    CornerRadius="8"
                                    Padding="14,10"
                                    Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding KeyFileName}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12"
                                                   Margin="0,3,0,0">
                                            <Run Text="For: "/>
                                            <Run Text="{Binding ModName}"/>
                                            <Run Text="  ·  Added "/>
                                            <Run Text="{Binding AddedAt, StringFormat='{}{0:MMM d, yyyy}'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource IconButton}"
                                            Content="✕"
                                            Command="{Binding DataContext.DeleteKeyCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Delete key"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right: Side panels -->
            <StackPanel Grid.Column="2">

                <!-- Apply to mod -->
                <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Apply key to mod"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="Select a key on the left, then pick a mod:"
                                   Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding InstalledMods}"
                                  x:Name="ModCombo"
                                  Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Apply Key"
                                Command="{Binding ApplyToModCommand}"
                                CommandParameter="{Binding SelectedItem, ElementName=ModCombo}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Manual entry -->
                <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Add key manually"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock Text="Mod name" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ManualModName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"/>

                        <TextBlock Text="File name (e.g. mymod.key)"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ManualFileName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"/>

                        <TextBlock Text="Key content"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ManualContent, UpdateSourceTrigger=PropertyChanged}"
                                 Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 Margin="0,0,0,10"/>

                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Save Key"
                                Command="{Binding AddManuallyCommand}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
