<UserControl x:Class="LSPDFRManager.Views.BrowseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <DockPanel Margin="28,24,28,16">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Browse Mods" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="Search lcpdfr.com for mods and install them directly."
                       Foreground="{StaticResource TextMuted}" FontSize="13"/>
        </StackPanel>

        <Border DockPanel.Dock="Top"
                Background="#1C0F00" CornerRadius="8" Padding="14,10"
                Margin="0,0,0,14">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ApiAvailable}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE814;" FontFamily="Segoe MDL2 Assets"
                           Foreground="#F59E0B" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="API server not running"
                               Foreground="#F59E0B" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Start LSPDFRManager.Api.exe alongside the app to enable Browse."
                               Foreground="#92601A" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"/>
            <Grid Grid.Column="2">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Text="Search lcpdfr.com…"
                           Foreground="#3D4F6A" FontSize="13"
                           Margin="11,0,0,0" VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <Button Grid.Column="4" Style="{StaticResource PrimaryButton}"
                    Content="&#xE721;  Search"
                    FontFamily="Segoe MDL2 Assets, Segoe UI"
                    Command="{Binding SearchCommand}"
                    IsEnabled="{Binding IsIdle}"/>
        </Grid>

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextMuted}" FontSize="12"/>
        </DockPanel>

        <ProgressBar DockPanel.Dock="Top"
                     Value="{Binding DownloadProgress}"
                     Maximum="100"
                     Margin="0,0,0,12"
                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>

        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Surface}"
                                CornerRadius="10" Padding="14,11" Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding Author}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11"/>
                                        <TextBlock Text=" · " Foreground="{StaticResource TextFaint}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding Type}"
                                                   Foreground="{StaticResource Accent}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                                                   Foreground="{StaticResource TextFaint}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource PrimaryButton}"
                                        Content="&#xE896;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Padding="10,6"
                                        ToolTip="Download &amp; Install"
                                        Command="{Binding DataContext.InstallCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2" Background="{StaticResource Surface}"
                    CornerRadius="10" Padding="16">
                <Grid>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                               FontSize="32" Foreground="{StaticResource TextFaint}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Select a result&#x0a;to see details"
                               Foreground="{StaticResource TextFaint}" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <DockPanel>
                    <DockPanel.Style>
                        <Style TargetType="DockPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DockPanel.Style>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="&#xE896;  Download &amp; Install"
                                FontFamily="Segoe MDL2 Assets, Segoe UI"
                                Command="{Binding InstallCommand}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{Binding IsIdle}"
                                Margin="0,0,0,8"/>
                        <Button Style="{StaticResource GhostButton}"
                                Content="&#xE774;  Open on lcpdfr.com"
                                FontFamily="Segoe MDL2 Assets, Segoe UI"
                                Command="{Binding OpenPageCommand}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DetailLabel}" Text="TITLE"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedResult.Title}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="AUTHOR"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedResult.Author, FallbackValue='—'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="VERSION"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedResult.Version, FallbackValue='—'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="TYPE"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedResult.Type, FallbackValue='—'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="DESCRIPTION"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedResult.Description}"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12" MaxHeight="120"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
