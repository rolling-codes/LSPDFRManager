<UserControl x:Class="LSPDFRManager.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackground}"
             FontFamily="Segoe UI">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Initializing..."
                       Foreground="{StaticResource TextStrong}"
                       FontSize="18" TextAlignment="Center" Margin="20"/>
            <ProgressBar Width="200" Height="6" IsIndeterminate="True" Margin="20"/>
            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12" TextAlignment="Center" Margin="20"/>
            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource ErrorText}"
                       FontSize="12" TextAlignment="Center" Margin="20"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
