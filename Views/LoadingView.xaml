<UserControl x:Class="LSPDFRManager.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Initializing..." Foreground="White" FontSize="18" TextAlignment="Center" Margin="20"/>
            <ProgressBar Width="200" Height="10" IsIndeterminate="True" Margin="20"/>
            <TextBlock x:Name="StatusText" Foreground="#888888" FontSize="12" TextAlignment="Center" Margin="20"/>
            <TextBlock x:Name="ErrorText" Foreground="#FF6B6B" FontSize="12" TextAlignment="Center" Margin="20" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
