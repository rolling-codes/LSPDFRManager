<UserControl x:Class="LSPDFRManager.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,16">

            <TextBlock Text="Backups &amp; Restore Points" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
            <TextBlock Text="Create, restore, and manage backup snapshots and restore points."
                       Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,24"/>

            <!-- Backup actions -->
            <TextBlock Text="BACKUPS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryButton}" Content="Create Backup Now"
                                Command="{Binding CreateBackupCommand}" IsEnabled="{Binding IsIdle}" Padding="20,10" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource GhostButton}" Content="Restore from File"
                                Command="{Binding RestoreBackupCommand}" IsEnabled="{Binding IsIdle}" Padding="16,10" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource GhostButton}" Content="Open Backup Folder"
                                Command="{Binding OpenBackupFolderCommand}" Padding="16,10"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Backups}" Background="Transparent" BorderThickness="0" MaxHeight="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding FileName}" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ModCount, StringFormat='{}{0} mods'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Restore Points -->
            <TextBlock Text="RESTORE POINTS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryButton}" Content="Restore Selected"
                                Command="{Binding RestorePointCommand}" IsEnabled="{Binding IsIdle}" Padding="16,10" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource GhostButton}" Content="Delete Selected"
                                Command="{Binding DeleteRestorePointCommand}" Padding="16,10"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding RestorePoints}" SelectedItem="{Binding SelectedRestorePoint}" Background="Transparent" BorderThickness="0" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding OperationName}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Progress log -->
            <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="16"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Margin="0,0,0,8"/>
                    <ScrollViewer MaxHeight="100">
                        <ItemsControl ItemsSource="{Binding ProgressLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ConsoleText}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="12"/>

            <!-- EUP Backup Easy Editor -->
            <TextBlock Text="EUP BACKUP EASY EDITOR" Style="{StaticResource SectionLabel}" Margin="0,20,0,0"/>
            <TextBlock Text="Select an installed EUP uniform and apply it to backup units. All edits create a timestamped backup first."
                       Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Source: EUP Uniforms -->
                <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="EUP Uniforms" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding EupDepartments}"
                                  SelectedItem="{Binding SelectedEupDepartment}"
                                  Margin="0,0,0,4" ToolTip="Filter by department"/>
                        <ComboBox ItemsSource="{Binding EupCounties}"
                                  SelectedItem="{Binding SelectedEupCounty}"
                                  Margin="0,0,0,4" ToolTip="Filter by county"/>
                        <ComboBox ItemsSource="{Binding EupGenders}"
                                  SelectedItem="{Binding SelectedEupGender}"
                                  Margin="0,0,0,8" ToolTip="Filter by gender"/>
                        <ListBox ItemsSource="{Binding EupUniforms}"
                                 SelectedItem="{Binding SelectedEupUniform}"
                                 Background="Transparent" BorderThickness="0" MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10">
                                            <Run Text="{Binding Department}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Gender}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding PedModel}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Style="{StaticResource GhostButton}" Content="Refresh Uniforms"
                                Command="{Binding RefreshEupUniformsCommand}" Margin="0,8,0,0" Padding="12,6"/>
                    </StackPanel>
                </Border>

                <!-- Target: Backup Units -->
                <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Backup Units" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding BackupDepartments}"
                                  SelectedItem="{Binding SelectedBackupDepartment}"
                                  Margin="0,0,0,4" ToolTip="Filter by department"/>
                        <ComboBox ItemsSource="{Binding BackupCounties}"
                                  SelectedItem="{Binding SelectedBackupCounty}"
                                  Margin="0,0,0,4" ToolTip="Filter by county/region"/>
                        <ComboBox ItemsSource="{Binding BackupCategories}"
                                  SelectedItem="{Binding SelectedBackupCategory}"
                                  Margin="0,0,0,8" ToolTip="Filter by unit category"/>
                        <ListBox ItemsSource="{Binding BackupUnits}"
                                 SelectedItem="{Binding SelectedBackupUnit}"
                                 Background="Transparent" BorderThickness="0" MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Agency}"
                                                   Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10">
                                            <Run Text="{Binding UnitType}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding PedModel}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Style="{StaticResource GhostButton}" Content="Refresh Units"
                                Command="{Binding RefreshBackupUnitsCommand}" Margin="0,8,0,0" Padding="12,6"/>
                    </StackPanel>
                </Border>

                <!-- Preview + Apply -->
                <Border Grid.Column="4" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Preview &amp; Apply" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Button Style="{StaticResource PrimaryButton}" Content="Preview Assignment"
                                Command="{Binding PreviewAssignmentCommand}"
                                IsEnabled="{Binding CanPreview}" Padding="12,8" Margin="0,0,0,8"/>

                        <!-- Mismatch warnings -->
                        <ItemsControl ItemsSource="{Binding MismatchWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3D2C00" CornerRadius="4" Padding="8,4" Margin="0,2">
                                        <TextBlock Text="{Binding}" Foreground="#FFB347"
                                                   FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Before/After -->
                        <TextBlock Text="Before:" Foreground="{StaticResource TextMuted}"
                                   FontSize="10" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding PreviewBefore, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="10"
                                 Background="#0D1117" Foreground="#8B949E"
                                 MaxHeight="80" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                        <TextBlock Text="After:" Foreground="{StaticResource TextMuted}"
                                   FontSize="10" Margin="0,6,0,2"/>
                        <TextBox Text="{Binding PreviewAfter, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="10"
                                 Background="#0D1117" Foreground="#3FB950"
                                 MaxHeight="80" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding ConfidenceLabel}" FontSize="11"
                                   Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="Apply"
                                    Command="{Binding ApplyAssignmentCommand}"
                                    IsEnabled="{Binding CanApply}" Padding="16,8" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource GhostButton}" Content="Revert"
                                    Command="{Binding RevertAssignmentCommand}"
                                    IsEnabled="{Binding CanRevert}" Padding="12,8"/>
                        </StackPanel>

                        <TextBlock Text="{Binding EupStatusMessage}" FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
