<UserControl x:Class="LSPDFRManager.Views.Components.ModCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="{StaticResource Surface}"
            CornerRadius="10"
            Margin="0,4"
            Padding="16,14"
            Opacity="{Binding Opacity}"
            BorderThickness="2,0,0,0"
            BorderBrush="{Binding StatusBrush}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Type badge + status -->
            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                <Border Width="48" Height="48" CornerRadius="8"
                        Background="{Binding TypeColor, Converter={StaticResource StringToBrush}}"
                        Margin="0,0,0,8">
                    <TextBlock Text="{Binding TypeLabel}"
                               Foreground="White" FontSize="9"
                               FontWeight="Bold" TextWrapping="Wrap"
                               TextAlignment="Center" Padding="4"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
                <!-- Confidence bar -->
                <Border CornerRadius="2" Background="#2D3A50" ClipToBounds="True">
                    <ProgressBar Value="{Binding DetectionScore, FallbackValue=100}"
                                 Height="3"
                                 ToolTip="{Binding DetectionScore, StringFormat='Detection: {0}%'}"/>
                </Border>
            </StackPanel>

            <!-- Main info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{Binding Name}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                    <!-- Risk badge -->
                    <Border Background="{Binding RiskBrush}" CornerRadius="4"
                            Padding="6,2" Margin="8,0,0,0">
                        <TextBlock Text="{Binding RiskTier}" Foreground="White"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <!-- Conflict badge -->
                    <Border Background="#DC2626" CornerRadius="4"
                            Padding="6,2" Margin="6,0,0,0"
                            Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <TextBlock Text="⚠ Conflict" Foreground="White"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,4">
                    <Run Text="{Binding Author, StringFormat='By {0}'}" Foreground="{StaticResource TextMuted}"/>
                    <Run Text="  ·  "/>
                    <Run Text="{Binding InstalledAt, StringFormat='{}{0:MMM d}'}"/>
                </TextBlock>

                <!-- Status text -->
                <TextBlock Foreground="{StaticResource TextFaint}" FontSize="11"
                           Text="{Binding StatusText}"/>

                <!-- Risk summary -->
                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10"
                           Text="{Binding RiskSummary}" Margin="0,2,0,0"/>

                <!-- Error message -->
                <Border Background="#2D1B1B" BorderBrush="#DC2626" BorderThickness="1"
                        CornerRadius="6" Padding="8" Margin="0,8,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#FCA5A5" FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <!-- Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <CheckBox Style="{StaticResource ToggleSwitch}"
                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                          Command="{Binding ToggleCommand}"
                          ToolTip="Enable / Disable (renames .dll on disk)"/>
                <Button Style="{StaticResource IconButton}"
                        Content="&#xE956;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Command="{Binding UninstallCommand}"
                        ToolTip="Uninstall"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
