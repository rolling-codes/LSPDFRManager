<UserControl x:Class="LSPDFRManager.Views.ReactPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI"
             Loaded="ReactPreviewView_Loaded">

    <Grid>
        <!-- Loading / error state -->
        <StackPanel x:Name="LoadingPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Visible">
            <TextBlock Text="React UI Preview"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextStrong}"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock x:Name="StatusLabel"
                       Text="Starting local API…"
                       FontSize="13"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- WebView2 — hidden until API is ready -->
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>
    </Grid>

</UserControl>
