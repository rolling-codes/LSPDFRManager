<UserControl x:Class="LSPDFRManager.Views.ModConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="28,24,28,12">
            <TextBlock Text="Mod Config Editor" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
            <TextBlock Text="Open, inspect, and edit XML configuration files for installed mods."
                       Foreground="{StaticResource TextMuted}" FontSize="13"/>
        </StackPanel>

        <!-- Main content: left file list + right editor -->
        <Grid Grid.Row="1" Margin="28,0,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: file list -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}" Padding="0">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom"
                            Style="{StaticResource GhostButton}"
                            Content="Browse..."
                            Command="{Binding BrowseCommand}"
                            AutomationProperties.Name="Browse for config file"
                            Margin="8" Padding="12,8"/>
                    <ListBox ItemsSource="{Binding ConfigFiles}"
                             SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="4,4,4,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="13"
                                           Padding="8,6"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FilePath}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter spacer -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Right panel: editor + validation + toolbar -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Editor TextBox -->
                <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="0">
                    <TextBox AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"
                             Text="{Binding EditorContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Padding="12"
                             Background="{StaticResource Surface}"
                             Foreground="{StaticResource TextPrimary}"
                             SpellCheck.IsEnabled="False"
                             AutomationProperties.Name="Config file editor"/>
                </Border>

                <!-- Validation error banner -->
                <Border Grid.Row="1"
                        Style="{StaticResource WarningBanner}"
                        Margin="0,8,0,0"
                        Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Foreground="{StaticResource TextStrong}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Bottom toolbar -->
                <DockPanel Grid.Row="2" Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButton}"
                                Content="Reload"
                                Command="{Binding ReloadCommand}"
                                AutomationProperties.Name="Reload file from disk"
                                Margin="0,0,8,0" Padding="14,8"/>
                        <Button Style="{StaticResource GhostButton}"
                                Content="Validate"
                                Command="{Binding ValidateCommand}"
                                AutomationProperties.Name="Validate XML"
                                Margin="0,0,8,0" Padding="14,8"/>
                        <Button Style="{StaticResource GhostButton}"
                                Content="Clear"
                                Command="{Binding ClearCommand}"
                                AutomationProperties.Name="Clear all open files"
                                Margin="0,0,8,0" Padding="14,8"/>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                AutomationProperties.Name="Save config file"
                                Padding="20,8"/>
                    </StackPanel>
                    <!-- Status bar -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- Bottom spacer -->
        <Border Grid.Row="2" Height="16"/>
    </Grid>
</UserControl>
