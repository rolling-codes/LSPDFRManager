<UserControl x:Class="LSPDFRManager.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LSPDFRManager.ViewModels"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <DockPanel Margin="28,24,28,16">

        <!-- ── Header ─────────────────────────────────────── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Mod Library" Style="{StaticResource SectionHeader}"/>
                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12">
                    <Run Text="{Binding TotalMods, Mode=OneWay}"/>
                    <Run Text=" mods installed · "/>
                    <Run Text="{Binding EnabledMods, Mode=OneWay}"/>
                    <Run Text=" enabled"/>
                </TextBlock>
            </StackPanel>
        </DockPanel>

        <!-- ── Search & Filter bar ────────────────────────── -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Search by name, author, or type…"
                           Foreground="#4B5563" FontSize="13"
                           Margin="11,0,0,0" VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FilterOptions}"
                      SelectedItem="{Binding SelectedFilter}"/>
        </Grid>

        <!-- ── Mod list ────────────────────────────────────── -->
        <ListBox DockPanel.Dock="Top"
                 ItemsSource="{Binding FilteredMods}"
                 SelectedItem="{Binding SelectedMod}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Mod Card -->
                    <Border Background="{StaticResource Surface}"
                            CornerRadius="10"
                            Margin="0,3"
                            Padding="14,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Type Badge -->
                            <Border Grid.Column="0"
                                    Width="48" Height="48"
                                    CornerRadius="8"
                                    Background="{Binding TypeColor, Converter={StaticResource StringToBrush}}"
                                    Margin="0,0,14,0">
                                <TextBlock Text="{Binding TypeLabel}"
                                           Foreground="White"
                                           FontSize="8"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Padding="3"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding Author}"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="12"/>
                                    <TextBlock Text=" · "
                                               Foreground="{StaticResource TextFaint}"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding TypeLabel}"
                                               FontSize="12"
                                               Foreground="{Binding TypeColor, Converter={StaticResource StringToBrush}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding InstalledAt, StringFormat='Installed {0:MMM d, yyyy}'}"
                                           Foreground="{StaticResource TextFaint}"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Controls -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          Command="{Binding DataContext.ToggleEnabledCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}"
                                          Margin="0,0,12,0"
                                          ToolTip="Enable / Disable"/>
                                <Button Style="{StaticResource IconButton}"
                                        Content="✕"
                                        FontSize="13"
                                        Command="{Binding DataContext.UninstallCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Uninstall"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ── Empty state ─────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                Padding="0,40"
                HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No mods found"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="16"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Install mods from the Install tab."
                           Foreground="{StaticResource TextFaint}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

    </DockPanel>
</UserControl>
