<UserControl x:Class="LSPDFRManager.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <DockPanel Margin="28,24,28,16">

        <!-- ── Header ─────────────────────────────────────── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Mod Library" Style="{StaticResource SectionHeader}"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12">
                        <Run Text="{Binding TotalMods, Mode=OneWay}"/>
                        <Run Text=" mods installed · "/>
                        <Run Text="{Binding EnabledMods, Mode=OneWay}"/>
                        <Run Text=" enabled"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <!-- ── Search & Filter ────────────────────────────── -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Search by name, author, or type…"
                           Foreground="#3D4F6A" FontSize="13"
                           Margin="11,0,0,0" VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FilterOptions}"
                      SelectedItem="{Binding SelectedFilter}"/>
        </Grid>

        <!-- ── Two-column content ─────────────────────────── -->
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- Mod list + empty state overlay -->
            <Grid Grid.Column="0">
                <ListBox ItemsSource="{Binding FilteredMods}"
                         SelectedItem="{Binding SelectedMod}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Surface}"
                                    CornerRadius="10"
                                    Margin="0,3"
                                    Padding="14,11">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Type badge -->
                                    <Border Grid.Column="0"
                                            Width="44" Height="44" CornerRadius="8"
                                            Background="{Binding TypeColor, Converter={StaticResource StringToBrush}}"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   Foreground="White" FontSize="7.5"
                                                   FontWeight="Bold" TextWrapping="Wrap"
                                                   TextAlignment="Center" Padding="3"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0">
                                            <Run Text="{Binding Author}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding InstalledAt, StringFormat='{}{0:MMM d, yyyy}'}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Controls -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <CheckBox Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                  Command="{Binding DataContext.ToggleEnabledCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}"
                                                  Margin="0,0,8,0"
                                                  ToolTip="Enable / Disable (renames .dll on disk)"/>
                                        <Button Style="{StaticResource IconButton}"
                                                Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="13"
                                                Command="{Binding DataContext.UninstallCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Uninstall"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state overlay -->
                <Border Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource Bg}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="40" Foreground="{StaticResource TextFaint}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="No mods found"
                                   Foreground="{StaticResource TextMuted}" FontSize="16"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Install mods from the Install tab."
                                   Foreground="{StaticResource TextFaint}" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Detail panel -->
            <Border Grid.Column="2" Background="{StaticResource Surface}"
                    CornerRadius="10" Padding="16">
                <Grid>

                <!-- Placeholder when nothing selected -->
                <StackPanel Visibility="{Binding HasNoSelectedMod, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                               FontSize="32" Foreground="{StaticResource TextFaint}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Select a mod to&#x0a;view details"
                               Foreground="{StaticResource TextFaint}" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Details when mod is selected -->
                <DockPanel Visibility="{Binding HasSelectedMod, Converter={StaticResource BoolToVis}}">

                    <!-- Actions at bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <Button Style="{StaticResource GhostButton}"
                                Content="&#xE838;  Open Folder"
                                FontFamily="Segoe MDL2 Assets, Segoe UI"
                                Command="{Binding OpenModFolderCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="10,7"/>
                    </StackPanel>

                    <!-- Scrollable detail content -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Type badge -->
                            <Border CornerRadius="6" Padding="10,4" Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="{Binding SelectedMod.TypeColor,
                                        Converter={StaticResource StringToBrush}}">
                                <TextBlock Text="{Binding SelectedMod.TypeLabel}"
                                           Foreground="White" FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="NAME"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedMod.Name}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="VERSION"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedMod.Version, FallbackValue='—'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="AUTHOR"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedMod.Author, FallbackValue='—'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="INSTALLED"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedMod.InstalledAt,
                                           StringFormat='{}{0:MMM d, yyyy HH:mm}'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="DLC PACK"/>
                            <TextBlock Style="{StaticResource DetailValue}"
                                       Text="{Binding SelectedMod.DlcPackName, FallbackValue='—'}"/>

                            <TextBlock Style="{StaticResource DetailLabel}" Text="INSTALLED FILES"/>
                            <ItemsControl ItemsSource="{Binding SelectedModFilesSample}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding SelectedModFilesMoreText}"
                                       Foreground="{StaticResource TextFaint}"
                                       FontSize="11" Margin="0,3,0,0"
                                       Visibility="{Binding HasMoreSelectedFiles,
                                           Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
                </Grid>
            </Border>
        </Grid>

    </DockPanel>
</UserControl>
