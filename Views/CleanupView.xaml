<UserControl x:Class="LSPDFRManager.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LSPDFRManager.ViewModels">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="LSPDFR Cleanup" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            <TextBlock FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value=""/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModeSelectStep}" Value="True"><Setter Property="Text" Value="Step 1 — Choose cleanup mode"/></DataTrigger>
                            <DataTrigger Binding="{Binding IsPreviewStep}"    Value="True"><Setter Property="Text" Value="Step 2 — Preview selected items"/></DataTrigger>
                            <DataTrigger Binding="{Binding IsConfirmStep}"    Value="True"><Setter Property="Text" Value="Step 3 — Confirm deletion"/></DataTrigger>
                            <DataTrigger Binding="{Binding IsResultStep}"     Value="True"><Setter Property="Text" Value="Step 4 — Result"/></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Page content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Step 1: Mode Select -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModeSelectStep}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextStrong}" FontSize="14" Margin="0,0,0,16">
                        Select a cleanup mode. A backup of selected files will be created before any deletion.
                        Nothing is deleted until you confirm on the final screen.
                    </TextBlock>

                    <!-- Mode 1 -->
                    <Border Margin="0,0,0,10" Padding="14,12" CornerRadius="8"
                            BorderThickness="1" BorderBrush="{StaticResource AccentBorder}"
                            Background="{StaticResource CardGradient}">
                        <StackPanel>
                            <RadioButton Content="Safe Core Reset" FontSize="14" FontWeight="SemiBold"
                                         Foreground="{StaticResource TextStrong}"
                                         IsChecked="{Binding SelectedModeIndex, Converter={StaticResource EqualToInt}, ConverterParameter=1}"/>
                            <TextBlock Margin="22,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="12">
                                Remove LSPDFR core DLL only. Third-party plugins, data folders, and RPH are not touched.
                                Low risk. Button confirm only.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Mode 4 -->
                    <Border Margin="0,0,0,10" Padding="14,12" CornerRadius="8"
                            BorderThickness="1" BorderBrush="{StaticResource AccentBorder}"
                            Background="{StaticResource CardGradient}">
                        <StackPanel>
                            <RadioButton Content="Selected Third-Party Plugin Cleanup" FontSize="14" FontWeight="SemiBold"
                                         Foreground="{StaticResource TextStrong}"
                                         IsChecked="{Binding SelectedModeIndex, Converter={StaticResource EqualToInt}, ConverterParameter=4}"/>
                            <TextBlock Margin="22,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="12">
                                Choose specific third-party plugins to remove. LSPDFR core and RPH are not shown.
                                Nothing is selected by default. Medium risk. Requires typed confirmation.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#F59E0B" FontSize="12"
                               Margin="0,8,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}"/>
                </StackPanel>

                <!-- Step 2: Preview -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewStep}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Risk / warning -->
                    <Border Margin="0,0,0,12" Padding="12,10" CornerRadius="6"
                            Background="#1A2845" BorderBrush="{StaticResource AccentBorder}" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Risk: " Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding RiskLabel}" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding WarningText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextStrong}" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Check the items you want to remove:"
                               Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="6"
                                        BorderBrush="{StaticResource AccentBorder}" BorderThickness="1"
                                        Background="{StaticResource CardGradient}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextStrong}" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              IsEnabled="{Binding IsBlocked, Converter={StaticResource InverseBool}}"
                                                              Margin="0,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" FontSize="12"
                                                                       Foreground="{StaticResource TextStrong}"/>
                                                            <TextBlock Text=" — " FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                            <TextBlock Text="{Binding RiskLabel}" FontSize="11"
                                                                       Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Step 3: Confirm -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfirmStep}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock TextWrapping="Wrap" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12">
                        A backup will be created first. If backup fails, no files will be deleted.
                    </TextBlock>

                    <TextBlock Text="{Binding WarningText}" TextWrapping="Wrap"
                               Foreground="{StaticResource TextStrong}" FontSize="13" Margin="0,0,0,16"/>

                    <!-- Typed confirmation (when required) -->
                    <StackPanel Visibility="{Binding RequiresTypedConfirm, Converter={StaticResource BoolToVis}}">
                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,6">
                            <Run Text="Type "/>
                            <Run Text="{Binding ConfirmPhrase, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
                            <Run Text=" to confirm:"/>
                        </TextBlock>
                        <TextBox Text="{Binding TypedConfirmation, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="8,6" Margin="0,0,0,8"
                                 Background="{StaticResource Surface}" Foreground="{StaticResource TextStrong}"
                                 BorderBrush="{StaticResource AccentBorder}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#F59E0B" FontSize="12"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}"/>
                </StackPanel>

                <!-- Step 4: Result -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsResultStep}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Cleanup complete."/>
                                <Setter Property="Foreground" Value="#22C55E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ApplyResult.Success}" Value="False">
                                        <Setter Property="Text" Value="Cleanup failed or partially failed."/>
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="{Binding ApplyResult.AbortReason}" TextWrapping="Wrap"
                               Foreground="#EF4444" FontSize="13" Margin="0,0,0,8"
                               Visibility="{Binding ApplyResult.AbortReason, Converter={StaticResource NullToCollapsed}}"/>

                    <StackPanel Visibility="{Binding ApplyResult.BackupZipPath, Converter={StaticResource NullToCollapsed}}">
                        <TextBlock Text="Backup created:" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                        <TextBlock Text="{Binding ApplyResult.BackupZipPath}" TextWrapping="Wrap"
                                   Foreground="{StaticResource AccentPrimary}" FontSize="12" Margin="0,2,0,8"/>
                    </StackPanel>

                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,4"
                               Visibility="{Binding ApplyResult.DeletedPaths.Count, Converter={StaticResource NonZeroToVisible}}">
                        <Run Text="Deleted "/>
                        <Run Text="{Binding ApplyResult.DeletedPaths.Count}"/>
                        <Run Text=" item(s):"/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding ApplyResult.DeletedPaths}"
                                  Visibility="{Binding ApplyResult.DeletedPaths.Count, Converter={StaticResource NonZeroToVisible}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#22C55E" Margin="8,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Foreground="#EF4444" FontSize="12" Margin="0,8,0,4"
                               Visibility="{Binding ApplyResult.FailedPaths.Count, Converter={StaticResource NonZeroToVisible}}">
                        <Run Text="Failed to delete "/>
                        <Run Text="{Binding ApplyResult.FailedPaths.Count}"/>
                        <Run Text=" item(s):"/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding ApplyResult.FailedPaths}"
                                  Visibility="{Binding ApplyResult.FailedPaths.Count, Converter={StaticResource NonZeroToVisible}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#EF4444" Margin="8,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                    Visibility="{Binding IsResultStep, Converter={StaticResource InverseBoolToVis}}"/>
            <Button Content="Back" Command="{Binding BackCommand}"
                    Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                    Visibility="{Binding IsResultStep, Converter={StaticResource InverseBoolToVis}}"/>

            <!-- Next (mode select → preview) -->
            <Button Content="Next" Command="{Binding NextCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Visibility="{Binding IsModeSelectStep, Converter={StaticResource BoolToVis}}"/>

            <!-- Proceed to confirm (preview → confirm) -->
            <Button Content="Review &amp; Confirm"
                    Style="{StaticResource PrimaryButton}"
                    Visibility="{Binding IsPreviewStep, Converter={StaticResource BoolToVis}}"
                    Click="ProceedToConfirm_Click"/>

            <!-- Delete (confirm → result) -->
            <Button Content="Delete Selected" Command="{Binding ConfirmCommand}"
                    Style="{StaticResource DangerButton}"
                    Visibility="{Binding IsConfirmStep, Converter={StaticResource BoolToVis}}"/>

            <!-- Done (result) -->
            <Button Content="Done" Command="{Binding CancelCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Visibility="{Binding IsResultStep, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

    </Grid>
</UserControl>
