<UserControl x:Class="LSPDFRManager.Views.InstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI"
             x:Name="Root">

    <DockPanel Margin="28,24,28,16">

        <!-- ── Header ─────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Install Mod" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="Drop a .zip / .rar / .7z archive or browse to select one."
                       Foreground="{StaticResource TextMuted}" FontSize="13"/>
        </StackPanel>

        <!-- ── Log panel (bottom) ─────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Surface}"
                CornerRadius="10"
                Margin="0,16,0,0"
                Height="160">
            <DockPanel Margin="14,10">
                <TextBlock DockPanel.Dock="Top"
                           Text="Log"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Log}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#94A3B8"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Main content ───────────────────────────────── -->
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Drop zone -->
            <Border Grid.Column="0"
                    x:Name="DropZone"
                    Background="{StaticResource Surface}"
                    CornerRadius="12"
                    BorderBrush="#374151"
                    BorderThickness="2"
                    AllowDrop="True"
                    Drop="DropZone_Drop"
                    DragOver="DropZone_DragOver"
                    DragLeave="DropZone_DragLeave"
                    MinHeight="200">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⬇" FontSize="36" Foreground="#374151"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Drop archive here"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,4"/>
                    <TextBlock Text=".zip · .rar · .7z"
                               Foreground="{StaticResource TextFaint}"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="Browse for file"
                            Command="{Binding BrowseCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Detection result panel -->
            <Border Grid.Column="2"
                    Background="{StaticResource Surface}"
                    CornerRadius="12"
                    Padding="20">
                <!-- No detection yet -->
                <StackPanel Visibility="{Binding HasNoDetection, Converter={StaticResource BoolToVis}}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Detection results will appear here."
                               Foreground="{StaticResource TextFaint}"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Detection results (overlay when available) -->
            <Border Grid.Column="2"
                    Background="{StaticResource Surface}"
                    CornerRadius="12"
                    Padding="20"
                    Visibility="{Binding HasDetection, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Install button at bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Install Mod"
                                Command="{Binding InstallCommand}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{Binding IsIdle}"/>
                        <Button Style="{StaticResource GhostButton}"
                                Content="Clear"
                                Command="{Binding ClearCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Detection info -->
                    <StackPanel>
                        <!-- Type badge row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border CornerRadius="6" Padding="10,4"
                                    Background="{Binding DetectedMod.TypeColor,
                                        Converter={StaticResource StringToBrush}}">
                                <TextBlock Text="{Binding DetectedMod.TypeLabel}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="6" Padding="8,4" Margin="8,0,0,0"
                                    Background="{StaticResource Surface2}">
                                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12">
                                    <Run Text="{Binding DetectedMod.ConfidenceLabel, Mode=OneWay}"/>
                                    <Run Text=" confidence"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Name row -->
                        <TextBlock Text="Mod name"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding DetectedMod.Name}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <!-- Version -->
                        <TextBlock Text="Version"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,0,0,3"/>
                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,0,0,10">
                            <Run Text="{Binding DetectedMod.Version, Mode=OneWay, FallbackValue='—'}"/>
                        </TextBlock>

                        <!-- Author override -->
                        <TextBlock Text="Author (optional)"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding AuthorOverride, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <!-- Warnings -->
                        <ItemsControl ItemsSource="{Binding DetectedMod.Warnings}"
                                      Visibility="{Binding DetectedMod.Warnings.Count,
                                          Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D1F07" CornerRadius="6"
                                            Padding="10,6" Margin="0,2">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#F59E0B"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Detecting spinner -->
                        <StackPanel Visibility="{Binding IsDetecting, Converter={StaticResource BoolToVis}}"
                                    Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Detecting…"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
