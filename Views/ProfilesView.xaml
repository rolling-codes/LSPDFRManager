<UserControl x:Class="LSPDFRManager.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Profiles list sidebar -->
        <Border Grid.Column="0" Background="{StaticResource Surface}" Margin="28,24,8,16" CornerRadius="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="12,12,12,8">
                    <TextBlock Text="PROFILES" Style="{StaticResource SectionLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Content="New"
                                Command="{Binding CreateProfileCommand}" Padding="12,6" Margin="0,0,6,0" FontSize="12"/>
                        <Button Style="{StaticResource GhostButton}" Content="Import"
                                Command="{Binding ImportProfileCommand}" Padding="12,6" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <ListBox DockPanel.Dock="Bottom" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" Margin="0,0,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="12,8">
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11">
                                    <Run Text="Last used: "/>
                                    <Run Text="{Binding LastUsedAt, TargetNullValue='Never', StringFormat='{}{0:yyyy-MM-dd}'}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Profile detail -->
        <StackPanel Grid.Column="1" Margin="8,24,28,16">
            <!-- Actions -->
            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16" Visibility="{Binding SelectedProfile, Converter={StaticResource StringToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedProfile.Name}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SelectedProfile.Notes}" Foreground="{StaticResource TextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <WrapPanel>
                        <Button Style="{StaticResource PrimaryButton}" Content="Apply Profile"
                                Command="{Binding ApplyProfileCommand}" Padding="18,10" Margin="0,0,8,8"/>
                        <Button Style="{StaticResource GhostButton}" Content="Duplicate"
                                Command="{Binding DuplicateProfileCommand}" Padding="14,10" Margin="0,0,8,8"/>
                        <Button Style="{StaticResource GhostButton}" Content="Export"
                                Command="{Binding ExportProfileCommand}" Padding="14,10" Margin="0,0,8,8"/>
                        <Button Style="{StaticResource GhostButton}" Content="Delete"
                                Command="{Binding DeleteProfileCommand}" Padding="14,10" Margin="0,0,8,8"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Progress log -->
            <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="16"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Margin="0,0,0,8"/>
                    <ScrollViewer MaxHeight="100">
                        <ItemsControl ItemsSource="{Binding ProgressLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ConsoleText}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>
