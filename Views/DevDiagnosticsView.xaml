<UserControl x:Class="LSPDFRManager.Views.DevDiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="28,24,28,12">
            <TextBlock Text="Developer Diagnostics" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
            <TextBlock Text="Feature flags, log tail, and support bundle export. Not shown to end users."
                       Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Style="{StaticResource PrimaryButton}" Content="Export Support Bundle"
                        Command="{Binding ExportBundleCommand}" Margin="0,0,8,0" Padding="20,10"/>
                <Button Style="{StaticResource GhostButton}" Content="Refresh Log"
                        Command="{Binding RefreshLogCommand}" Padding="16,10"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}"
                       FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="28,0,28,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Feature flags -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="FEATURE FLAGS" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FeatureRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          Background="{StaticResource BgCard}"
                          BorderBrush="{StaticResource Border}"
                          BorderThickness="1"
                          RowBackground="{StaticResource BgCard}"
                          AlternatingRowBackground="{StaticResource BgHover}"
                          Foreground="{StaticResource TextPrimary}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource Border}"
                          HeadersVisibility="Column">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource BgCard}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled, Mode=OneWay}" Width="40"/>
                        <DataGridTextColumn Header="Feature" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="90"/>
                        <DataGridTemplateColumn Header="Actions" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource GhostButton}" Content="Toggle"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.ToggleFeatureCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Padding="6,3" Margin="0,0,4,0" FontSize="11"/>
                                        <Button Style="{StaticResource GhostButton}" Content="Reset"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.ResetFeatureCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Padding="6,3" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Log tail -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="RECENT LOG (LAST 100 LINES)" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BgCard}"
                              BorderBrush="{StaticResource Border}" BorderThickness="1">
                    <TextBox Text="{Binding LogTail, Mode=OneWay}"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimary}"
                             FontFamily="Consolas" FontSize="11"
                             IsReadOnly="True" TextWrapping="NoWrap"
                             BorderThickness="0" Padding="8"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Progress log -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Margin="0,0,0,0" Padding="28,8" MaxHeight="80">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ProgressLog}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontFamily="Consolas"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
