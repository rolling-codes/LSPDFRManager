<UserControl x:Class="LSPDFRManager.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,26,28,20">

            <Border Margin="0,0,0,18" CornerRadius="14" Padding="18,14" BorderBrush="{StaticResource AccentBorder}" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F2B56" Offset="0"/>
                        <GradientStop Color="#1a5dcc" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusChip}" VerticalAlignment="Center" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource StatusOk}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Operational" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Command Center" Foreground="White" FontSize="27" FontWeight="Bold"/>
                        <TextBlock Text="Mission control for your GTA V and LSPDFR ecosystem."
                               Foreground="{StaticResource TextMuted}" FontSize="14" Margin="0,6,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <TextBlock Text="ENVIRONMENT STATUS" Style="{StaticResource SectionLabel}"/>
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="GAME PATH" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Status.GtaPath}" Foreground="{StaticResource TextStrong}" FontSize="13" FontWeight="SemiBold" Margin="0,7,0,0" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource StatusError}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status.IsGtaPathValid}" Value="True"><Setter Property="Fill" Value="{StaticResource StatusOk}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Validated" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="LSPDFR CORE" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Status.IsLspdfrInstalled, StringFormat='{}{0}'}" Foreground="{StaticResource TextStrong}" FontSize="22" FontWeight="Bold" Margin="0,7,0,0"/>
                        <TextBlock Text="Core install state" Foreground="{StaticResource TextSubtle}" FontSize="12" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="MODS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource TextStrong}" FontSize="22" FontWeight="Bold" Margin="0,7,0,0">
                            <Run Text="{Binding Status.EnabledModCount, Mode=OneWay}"/><Run Text=" enabled"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource TextSubtle}" FontSize="12" Margin="0,8,0,0">
                            <Run Text="{Binding Status.DisabledModCount, Mode=OneWay}"/><Run Text=" disabled"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="PLUGIN STORAGE" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Status.StorageUsed}" Foreground="{StaticResource TextStrong}" FontSize="22" FontWeight="Bold" Margin="0,7,0,0"/>
                        <TextBlock Text="Current plugin footprint" Foreground="{StaticResource TextSubtle}" FontSize="12" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource ActionGroupCard}" Margin="0,0,0,16" BorderBrush="{StaticResource AccentBorder}" BorderThickness="1">
                <WrapPanel>
                    <Button Style="{StaticResource PrimaryButton}" Content="Launch RPH" Command="{Binding LaunchRphCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Launch GTA V" Command="{Binding LaunchGtaCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Scan Plugins" Command="{Binding ScanPluginsCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Analyze Crash Logs" Command="{Binding AnalyzeCrashLogsCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Create Backup" Command="{Binding CreateBackupCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Safe Launch Mode" Command="{Binding ApplySafeLaunchCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Open GTA V Folder" Command="{Binding OpenGtaFolderCommand}" Margin="0,0,10,10"/>
                    <Button Style="{StaticResource GhostButton}" Content="Open Logs Folder" Command="{Binding OpenLogsFolderCommand}" Margin="0,0,10,10"/>
                </WrapPanel>
            </Border>

            <TextBlock Text="TELEMETRY" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource TelemetryCard}" Margin="0,0,0,12" BorderBrush="{StaticResource AccentBorder}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Text="Last Backup" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                        <TextBlock Text="{Binding Status.LastBackupDisplay}" Foreground="{StaticResource TextStrong}" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="Last Diagnostics" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                        <TextBlock Text="{Binding Status.LastDiagnosticsDisplay}" Foreground="{StaticResource TextStrong}" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Crash Log Activity" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                        <TextBlock Foreground="{StaticResource TextStrong}" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0">
                            <TextBlock.Text><Binding Path="Status.LastCrashDetected" TargetNullValue="None detected"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PATROL READINESS -->
            <TextBlock Text="PATROL READINESS"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="11" FontWeight="ExtraBold"
                       Margin="0,24,0,8"/>
            <Border Style="{StaticResource TelemetryCard}" Margin="0,0,0,16">
                <StackPanel>

                    <!-- Header row: status + check button -->
                    <DockPanel Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right"
                                Content="Check Now"
                                Command="{Binding Readiness.CheckCommand}"
                                IsEnabled="{Binding Readiness.IsChecking, Converter={StaticResource InverseBool}}"
                                Padding="12,5"
                                Style="{StaticResource GhostButton}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Readiness.StatusText}"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextStrong}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding Readiness.CheckedAt}"
                                       Foreground="{StaticResource TextFaint}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Checking indicator -->
                    <Border Visibility="{Binding Readiness.IsChecking, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                            Margin="0,0,0,8">
                        <TextBlock Text="Checking…" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </Border>

                    <!-- Blocking issues -->
                    <ItemsControl ItemsSource="{Binding Readiness.BlockingIssues}"
                                  Visibility="{Binding Readiness.HasBlockingIssues, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="&#x2715; " Foreground="{StaticResource DangerBrush}"
                                               FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource DangerBrush}"
                                               FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Warnings -->
                    <ItemsControl ItemsSource="{Binding Readiness.Warnings}"
                                  Visibility="{Binding Readiness.HasWarnings, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="&#x26A0; " Foreground="#F59E0B"
                                               FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding}" Foreground="#F59E0B"
                                               FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Passing checks count -->
                    <TextBlock Visibility="{Binding Readiness.HasPassingChecks, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                               Foreground="{StaticResource TextFaint}" FontSize="11" Margin="0,4,0,0">
                        <Run Text="{Binding Readiness.PassingChecks.Count, Mode=OneWay}"/>
                        <Run Text=" checks passed"/>
                    </TextBlock>

                </StackPanel>
            </Border>

            <TextBlock Text="COMPATIBILITY" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource TelemetryCard}" Margin="0,0,0,16" BorderBrush="{StaticResource AccentBorder}" BorderThickness="1">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Refresh"
                                Command="{Binding Compatibility.RefreshCommand}" Padding="10,5"/>
                        <TextBlock Text="Detected component versions" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Border Visibility="{Binding Compatibility.IsRefreshing, Converter={StaticResource BoolToVis}}" Padding="0,4,0,8">
                        <TextBlock Text="Detecting…" Foreground="{StaticResource TextFaint}" FontSize="12"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding CompatibilityRows}" Visibility="{Binding Compatibility.HasBundle, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Version}" Foreground="{StaticResource TextStrong}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" Foreground="{StaticResource TextSubtle}" FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
