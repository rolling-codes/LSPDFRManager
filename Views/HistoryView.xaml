<UserControl x:Class="LSPDFRManager.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}"
             FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="28,24,28,12">
            <TextBlock Text="Change History" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
            <TextBlock Text="All operations performed by LSPDFR Manager." Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Style="{StaticResource GhostButton}" Content="Export JSON" Command="{Binding ExportJsonCommand}" Padding="14,8" Margin="0,0,8,0"/>
                <Button Style="{StaticResource GhostButton}" Content="Export TXT" Command="{Binding ExportTxtCommand}" Padding="14,8" Margin="0,0,8,0"/>
                <Button Style="{StaticResource GhostButton}" Content="Clear History" Command="{Binding ClearHistoryCommand}" Padding="14,8" Margin="0,0,8,0"/>
                <Button Style="{StaticResource GhostButton}" Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,8"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter:" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding ActionFilters}" SelectedItem="{Binding SelectedAction}" Width="160" Margin="0,0,16,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Tag="Search…"/>
            </StackPanel>
        </StackPanel>

        <!-- List -->
        <Border Grid.Row="1" Background="{StaticResource Surface}" CornerRadius="10" Margin="28,0,28,0">
            <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14,10" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding OccurredAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Action}" Foreground="{StaticResource AccentPrimary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding Entries.Count, StringFormat='{}{0} entries'}" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="28,8,28,16"/>
    </Grid>
</UserControl>
