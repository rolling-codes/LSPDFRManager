<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ Base palette (semantic) ═══════════════════════════════ -->
    <SolidColorBrush x:Key="AppBackground"      Color="#0A0C10"/>
    <SolidColorBrush x:Key="PanelBackground"    Color="#161B22"/>
    <SolidColorBrush x:Key="PanelAltBackground" Color="#21262D"/>
    <SolidColorBrush x:Key="SidebarBackground"  Color="#010409"/>

    <SolidColorBrush x:Key="BorderSubtle"       Color="#30363D"/>

    <SolidColorBrush x:Key="AccentPrimary"      Color="#58A6FF"/>
    <SolidColorBrush x:Key="AccentSecondary"    Color="#1F6FEB"/>

    <SolidColorBrush x:Key="SuccessBrush"       Color="#3FB950"/>
    <SolidColorBrush x:Key="WarningBrush"       Color="#D29922"/>
    <SolidColorBrush x:Key="DangerBrush"        Color="#F85149"/>

    <SolidColorBrush x:Key="TextStrong"         Color="#F0F6FC"/>
    <SolidColorBrush x:Key="TextMuted"          Color="#8B949E"/>
    <SolidColorBrush x:Key="TextSubtle"         Color="#484F58"/>

    <!-- Error banner -->
    <SolidColorBrush x:Key="ErrorBackground"    Color="#2D1B1B"/>
    <SolidColorBrush x:Key="ErrorBorder"        Color="#DC2626"/>
    <SolidColorBrush x:Key="ErrorText"          Color="#FCA5A5"/>

    <!-- ══ Compatibility aliases (keep existing keys working) ════ -->
    <SolidColorBrush x:Key="Bg"          Color="#0A0C10"/>
    <SolidColorBrush x:Key="Surface"     Color="#161B22"/>
    <SolidColorBrush x:Key="Surface2"    Color="#21262D"/>
    <SolidColorBrush x:Key="Sidebar"     Color="#010409"/>
    <SolidColorBrush x:Key="Border"      Color="#30363D"/>
    <SolidColorBrush x:Key="Accent"      Color="#58A6FF"/>
    <SolidColorBrush x:Key="AccentDark"  Color="#1F6FEB"/>
    <SolidColorBrush x:Key="Success"     Color="#3FB950"/>
    <SolidColorBrush x:Key="Warning"     Color="#D29922"/>
    <SolidColorBrush x:Key="Danger"      Color="#F85149"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#F0F6FC"/>
    <SolidColorBrush x:Key="TextFaint"   Color="#484F58"/>

</ResourceDictionary>
